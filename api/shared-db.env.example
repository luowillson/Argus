# Shared development database template.
#
# Copy the DATABASE_URL value from your hosted shared Postgres database into
# api/.env. The database must be Postgres with pgvector and pg_trgm available.
#
# We self-host on a GCP `e2-micro` VM (Always Free tier) and reach it over a
# Tailscale tailnet — Postgres is not exposed publicly. Before this URL works,
# you must:
#   1. Install Tailscale and ask the migrator to invite you to the tailnet
#   2. Replace <vm-tailscale-ip> below with the VM's 100.x.y.z address
#
# See MIGRATION.md at the repo root for the full setup runbook.
#
# Keep Redis local unless your team has also provisioned a shared Redis. Redis
# is used for Celery queues and does not need to be shared for the paper cache
# to be shared.

DATABASE_URL=postgresql+psycopg://veros:<password>@<vm-tailscale-ip>:5432/veros
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=0
DB_POOL_TIMEOUT=10
REDIS_URL=redis://localhost:6379/0

# Citation graph provider configuration.
SEMANTIC_SCHOLAR_API_KEY=
CITATION_MAX_REFERENCES=150
CITATION_HTTP_TIMEOUT=12
SEMANTIC_SCHOLAR_MIN_INTERVAL_SECONDS=1.05

# Use a per-developer identity so saved papers do not all land under demo-user.
DEMO_USER_ID=<your-name>
DEMO_USER_EMAIL=<your-name>@veros.local
