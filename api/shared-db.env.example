# Shared development database template.
#
# Copy the DATABASE_URL value from your hosted shared Postgres database into
# api/.env. The database must be Postgres with pgvector available.
#
# Keep Redis local unless your team has also provisioned a shared Redis. Redis
# is used for Celery queues and does not need to be shared for the paper cache
# to be shared.

DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:5432/<database>?sslmode=require
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=0
DB_POOL_TIMEOUT=10
REDIS_URL=redis://localhost:6379/0

# Use a per-developer identity so saved papers do not all land under demo-user.
DEMO_USER_ID=<your-name>
DEMO_USER_EMAIL=<your-name>@veros.local
