# Local Docker Postgres. For the shared team database, replace this with the
# hosted pgvector Postgres URL from shared-db.env.example.
DATABASE_URL=postgresql+psycopg://veros:veros@localhost:5432/veros
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=10
# DEBUG=true surfaces exception messages in 500 responses. Leave false in prod.
DEBUG=false
REDIS_URL=redis://localhost:6379/0

# LLM provider
LLM_PROVIDER=gemini

# Gemini (OpenAI-compatible mode). Gemma models do not support JSON mode; the
# provider auto-detects and falls back to prompt-based JSON extraction.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-3-flash-preview

# OpenReview. Optional — only needed for auth-gated venues.
OPENREVIEW_USERNAME=
OPENREVIEW_PASSWORD=

# Embeddings (M7). Loaded by the worker process.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Demo user — replaces Clerk for the MVP. Use per-developer values when
# connecting to the shared database so saved papers stay separate.
DEMO_USER_ID=demo-user
DEMO_USER_EMAIL=demo@veros.local

CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
