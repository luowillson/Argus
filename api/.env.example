# Local Docker Postgres. For the shared team database, replace this with the
# hosted pgvector Postgres URL from shared-db.env.example.
DATABASE_URL=postgresql+psycopg://veros:veros@localhost:5432/veros
DB_POOL_SIZE=2
DB_MAX_OVERFLOW=0
DB_POOL_TIMEOUT=10
REDIS_URL=redis://localhost:6379/0

# LLM provider switch: "zai" | "gemini"
LLM_PROVIDER=zai

# Z.AI (OpenAI-compatible at /api/paas/v4/). Coding Plan keys work for chat completions.
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
ZAI_MODEL=glm-4.6

# Gemini (OpenAI-compatible mode). Free tier: gemini-2.5-flash.
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.5-flash

# OpenReview. Optional — only needed for auth-gated venues.
OPENREVIEW_USERNAME=
OPENREVIEW_PASSWORD=

# Embeddings (M7). Loaded by the worker process.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Demo user — replaces Clerk for the MVP. Use per-developer values when
# connecting to the shared database so saved papers stay separate.
DEMO_USER_ID=demo-user
DEMO_USER_EMAIL=demo@veros.local

CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
